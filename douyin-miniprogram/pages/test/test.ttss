.phase {
  padding: 20rpx 0;
}

.hint {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 30rpx;
}

.test-list {
  margin-bottom: 30rpx;
}

.test-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: white;
  border-radius: 15rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid #eee;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.test-item.selected {
  border-color: #4A90D9;
  background: #F0F7FF;
}

.test-info {
  flex: 1;
}

.test-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.test-desc {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 8rpx;
}

.test-count {
  font-size: 22rpx;
  color: #999;
}

.test-check {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #4A90D9;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.selected-info {
  text-align: center;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 30rpx;
}

.progress-bar {
  height: 8rpx;
  background: #eee;
  border-radius: 4rpx;
  margin-bottom: 10rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4A90D9, #357ABD);
  border-radius: 4rpx;
  transition: width 0.3s;
}

.progress-text {
  font-size: 24rpx;
  color: #666;
  display: block;
  text-align: right;
  margin-bottom: 30rpx;
}

.question-card {
  background: white;
  border-radius: 15rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.question-text {
  font-size: 32rpx;
  color: #333;
  line-height: 1.6;
  display: block;
  margin-bottom: 40rpx;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.option {
  background: #F5F5F5;
  border-radius: 10rpx;
  padding: 30rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.option.selected {
  background: #4A90D9;
  color: white;
  border-color: #4A90D9;
}

.nav-buttons {
  display: flex;
  gap: 20rpx;
}

.btn-secondary {
  flex: 1;
  background: #f0f0f0;
  color: #666;
  border: none;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 30rpx;
}

.btn-secondary:disabled {
  opacity: 0.5;
}

.form-group {
  background: white;
  border-radius: 15rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.form-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #eee;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.radio-group, .checkbox-group {
  display: flex;
  gap: 20rpx;
}

.radio-item, .checkbox-item {
  flex: 1;
  background: #F5F5F5;
  border-radius: 10rpx;
  padding: 20rpx;
  text-align: center;
  font-size: 26rpx;
  border: 2rpx solid transparent;
}

.radio-item.selected, .checkbox-item.selected {
  background: #E8F4FC;
  border-color: #4A90D9;
  color: #4A90D9;
}