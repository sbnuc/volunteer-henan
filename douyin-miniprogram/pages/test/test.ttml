<view class="container">
  <!-- Test Selection Phase -->
  <view class="phase" tt:if="{{phase === 'select'}}">
    <view class="section-title">选择性格测试</view>
    <text class="hint">请至少选择2个测试</text>

    <view class="test-list">
      <view class="test-item {{selectedTests.includes('mbti') ? 'selected' : ''}}" bindtap="toggleTest" data-test="mbti">
        <view class="test-info">
          <text class="test-name">MBTI性格测试</text>
          <text class="test-desc">了解你的性格类型</text>
          <text class="test-count">24道题目</text>
        </view>
        <view class="test-check">
          <text tt:if="{{selectedTests.includes('mbti')}}">✓</text>
        </view>
      </view>

      <view class="test-item {{selectedTests.includes('holland') ? 'selected' : ''}}" bindtap="toggleTest" data-test="holland">
        <view class="test-info">
          <text class="test-name">霍兰德职业兴趣</text>
          <text class="test-desc">发现你的职业兴趣类型</text>
          <text class="test-count">30道题目</text>
        </view>
        <view class="test-check">
          <text tt:if="{{selectedTests.includes('holland')}}">✓</text>
        </view>
      </view>

      <view class="test-item {{selectedTests.includes('disc') ? 'selected' : ''}}" bindtap="toggleTest" data-test="disc">
        <view class="test-info">
          <text class="test-name">DISC性格测试</text>
          <text class="test-desc">了解你的行为风格</text>
          <text class="test-count">20道题目</text>
        </view>
        <view class="test-check">
          <text tt:if="{{selectedTests.includes('disc')}}">✓</text>
        </view>
      </view>
    </view>

    <view class="selected-info">
      <text>已选择 {{selectedTests.length}} 个测试</text>
    </view>

    <button class="btn-primary" disabled="{{selectedTests.length < 2}}" bindtap="startTesting">确认并开始测试</button>
  </view>

  <!-- Testing Phase -->
  <view class="phase" tt:if="{{phase === 'testing'}}">
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{progress}}%"></view>
    </view>
    <text class="progress-text">{{currentQuestion + 1}} / {{totalQuestions}}</text>

    <view class="question-card">
      <text class="question-text">{{currentQuestionData.q}}</text>

      <view class="options">
        <view class="option {{selectedOption === 0 ? 'selected' : ''}}" bindtap="selectOption" data-index="0">
          <text>{{currentQuestionData.options[0]}}</text>
        </view>
        <view class="option {{selectedOption === 1 ? 'selected' : ''}}" bindtap="selectOption" data-index="1">
          <text>{{currentQuestionData.options[1]}}</text>
        </view>
      </view>
    </view>

    <view class="nav-buttons">
      <button class="btn-secondary" bindtap="prevQuestion" disabled="{{currentQuestion === 0}}">上一题</button>
      <button class="btn-primary" bindtap="nextQuestion">{{isLastQuestion ? '完成' : '下一题'}}</button>
    </view>
  </view>

  <!-- Score Input Phase -->
  <view class="phase" tt:if="{{phase === 'score'}}">
    <view class="section-title">输入高考信息</view>

    <view class="form-group">
      <text class="form-label">高考分数</text>
      <input class="form-input" type="number" placeholder="请输入分数" value="{{score}}" bindinput="onScoreInput" />
    </view>

    <view class="form-group">
      <text class="form-label">省排名位次</text>
      <input class="form-input" type="number" placeholder="请输入位次" value="{{ranking}}" bindinput="onRankingInput" />
    </view>

    <view class="form-group">
      <text class="form-label">首选科目</text>
      <view class="radio-group">
        <view class="radio-item {{subjectGroup === 'phys' ? 'selected' : ''}}" bindtap="selectSubjectGroup" data-group="phys">
          <text>物理组</text>
        </view>
        <view class="radio-item {{subjectGroup === 'hist' ? 'selected' : ''}}" bindtap="selectSubjectGroup" data-group="hist">
          <text>历史组</text>
        </view>
      </view>
    </view>

    <view class="form-group">
      <text class="form-label">再选科目</text>
      <view class="checkbox-group">
        <view class="checkbox-item {{checkedSubjects.includes('化学') ? 'selected' : ''}}" bindtap="toggleSubject" data-subject="化学">
          <text>化学</text>
        </view>
        <view class="checkbox-item {{checkedSubjects.includes('生物') ? 'selected' : ''}}" bindtap="toggleSubject" data-subject="生物">
          <text>生物</text>
        </view>
        <view class="checkbox-item {{checkedSubjects.includes('政治') ? 'selected' : ''}}" bindtap="toggleSubject" data-subject="政治">
          <text>政治</text>
        </view>
        <view class="checkbox-item {{checkedSubjects.includes('地理') ? 'selected' : ''}}" bindtap="toggleSubject" data-subject="地理">
          <text>地理</text>
        </view>
      </view>
    </view>

    <button class="btn-primary" bindtap="generateResult">生成推荐结果</button>
  </view>
</view>